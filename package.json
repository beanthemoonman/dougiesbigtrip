{
  "name": "hl-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "nav:bake": "tsx tools/navbake/bake.ts",
    "assets:lightmap": "oiiotool assets/maps/de_greybox/lightmap.exr --clamp:min=0:max=1 -d uint8 -o assets/maps/de_greybox/lightmap_ldr.png && toktx --t2 --encode uastc --uastc_quality 3 --zcmp 18 --assign_oetf linear assets/maps/de_greybox/lightmap.ktx2 assets/maps/de_greybox/lightmap_ldr.png"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "recast-navigation": "^0.43.1",
    "stats.js": "^0.17.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^26.1.1",
    "@types/stats.js": "^0.17.3",
    "@types/three": "^0.170.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
