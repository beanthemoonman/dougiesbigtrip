# Phase 17–18 — Credentials for the docker compose stack.
# Copy to .env and fill in. .env is gitignored; never commit real values.

# -- Postgres ----------------------------------------------------------
POSTGRES_USER=dougys
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=dougys
# Docker Compose does NOT expand $VAR references inside the .env file itself.
# Type the full connection string; keep it in sync with the user/password/db
# above.  Characters meaningful to a URL (@, :, /, #, ?, &) in the password
# must be percent-encoded (e.g. p@ss → p%40ss).
DATABASE_URL=postgres://dougys:CHANGE_ME@db:5432/dougys

# -- Keycloak ----------------------------------------------------------
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
# Public URL Keycloak is reached at, including scheme, port and /auth.
# Defaults to https://localhost:8443/auth — set it for a real deployment.
KC_HOSTNAME=

# Obtain these from the Google Cloud Console → APIs & Services →
# Credentials → Create OAuth 2.0 Client ID (Web application).
# Authorised redirect URI:  https://<your-host>/auth/realms/counter-douglas/broker/google/endpoint
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
