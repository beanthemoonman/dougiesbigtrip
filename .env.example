# Phase 18 — Database credentials (used by docker compose and the Rust server).
# Copy to .env and fill in. .env is gitignored; never commit real values.
#
# docker compose up pulls these for both the `db` service and the `server`
# (DATABASE_URL). Keycloak uses KC_DB_*.
# NOTE: POSTGRES_PASSWORD is interpolated into DATABASE_URL verbatim. Characters
# with meaning in a URL (@ : / ? # % [ ]) will produce a malformed connection
# string — either avoid them or percent-encode them in DATABASE_URL below.
POSTGRES_USER=dougys
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=dougys
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Phase 17 — Keycloak admin credentials (keep in .env, never committed).
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
